{
  "version": 2,
  "installCommand": "npm install && npm install --include=dev --prefix client",
  "buildCommand": "(cd client && npm run build)",
  "outputDirectory": "client/dist",
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
